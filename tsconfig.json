{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "types": ["node"],
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "allowImportingTsExtensions": true,
    "noEmit": true, // required when using this flag
  },
  "include": ["src/**/*"],
}
